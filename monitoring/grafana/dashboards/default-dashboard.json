{
  "id": null,
  "title": "WebAPI - HTTP Requests",
  "uid": "webapi-http-requests",
  "schemaVersion": 30,
  "version": 1,
  "panels": [
    {
      "type": "graph",
      "title": "Requests per second (5m)",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(http_requests_received_total[5m])) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "type": "stat",
      "title": "WebAPI Health (up)",
      "gridPos": {"x": 0, "y": 8, "w": 6, "h": 4},
      "targets": [
        {
          "expr": "avg(up{job=\"webapi\"})",
          "legendFormat": "",
          "refId": "B"
        }
      ],
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "index": 0 },
                "1": { "text": "OK", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 0.5, "color": "green" }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"values": false, "calcs": ["last"], "fields": ""},
        "orientation": "horizontal",
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "type": "stat",
      "title": "DB Check",
      "gridPos": {"x": 0, "y": 12, "w": 4, "h": 3},
      "targets": [ { "expr": "webapi_db_up", "refId": "D" } ],
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "index": 0 }, "1": { "text": "OK", "index": 1 } } } ],
          "thresholds": { "mode": "absolute", "steps": [ { "value": null, "color": "red" }, { "value": 0.5, "color": "green" } ] },
          "unit": "none"
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["last"] }, "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "Redis Check",
      "gridPos": {"x": 4, "y": 12, "w": 4, "h": 3},
      "targets": [ { "expr": "webapi_redis_up", "refId": "E" } ],
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "index": 0 }, "1": { "text": "OK", "index": 1 } } } ],
          "thresholds": { "mode": "absolute", "steps": [ { "value": null, "color": "red" }, { "value": 0.5, "color": "green" } ] },
          "unit": "none"
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["last"] }, "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "RabbitMQ Check",
      "gridPos": {"x": 8, "y": 12, "w": 4, "h": 3},
      "targets": [ { "expr": "webapi_rabbitmq_up", "refId": "F" } ],
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "index": 0 }, "1": { "text": "OK", "index": 1 } } } ],
          "thresholds": { "mode": "absolute", "steps": [ { "value": null, "color": "red" }, { "value": 0.5, "color": "green" } ] },
          "unit": "none"
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["last"] }, "colorMode": "value" }
    },
    {
      "type": "graph",
      "title": "Response codes (5m increase)",
      "gridPos": {"x": 6, "y": 8, "w": 18, "h": 8},
      "targets": [
        {
          "expr": "sum(increase(http_requests_received_total[5m])) by (code)",
          "legendFormat": "{{code}}",
          "refId": "C"
        }
      ],
      "datasource": "Prometheus"
    }
  ],
  "time": {"from": "now-1h", "to": "now"}
}
