# Example environment variables for local development
# Leave APP_SETTINGS__EMAILCOOLDOWNSECONDS empty to use default (server-side default)
APP_SETTINGS__EMAILCOOLDOWNSECONDS=

# Other env vars (examples)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=projectdb
REDIS_CONNECTION=redis:6379
RABBITMQ_CONNECTION=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_EMAIL_QUEUE=emails
JWT_SETTINGS_SECRET=
JWT_SETTINGS_ISSUER=
JWT_SETTINGS_AUDIENCE=
JWT_SETTINGS_EXPIRATIONMINUTES=60
METRICS_API_KEY=
EMAIL_SERVER=
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_ENABLESSL=true# PostgreSQL database settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=coreapi-postgre-maindb

# Redis connection string
REDIS_CONNECTION=redis:6379

# RabbitMQ settings
RABBITMQ_CONNECTION=amqp://admin:admin@rabbitmq:5672/
RABBITMQ_EMAIL_QUEUE=email.queue

# App settings (injected into AppSettings via env-binding)
APP_SETTINGS__ProjectName=CoreAPI
APP_SETTINGS__ProjectOwner="Your Name or Company"
APP_SETTINGS__BASEURL=http://localhost:5000
APP_SETTINGS__INTERFACEURL=http://localhost:5001

# JWT settings (required for authentication)
JWT_SETTINGS_SECRET=your-jwt-secret
JWT_SETTINGS_ISSUER=your-jwt-issuer
JWT_SETTINGS_AUDIENCE=your-jwt-audience
JWT_SETTINGS_EXPIRATIONMINUTES=60

# Email (SMTP) settings
EMAIL_SERVER=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your.email@example.com
EMAIL_PASSWORD=your-email-password
EMAIL_ENABLESSL=true

# RabbitMQ user/pass for broker service
RABBITMQ_USER=admin
RABBITMQ_PASS=admin

# Prometheus metrics API key (protect /metrics endpoint)
METRICS_API_KEY=your-metrics-api-key-change-me

# Grafana admin password (used by docker-compose provisioning)
GRAFANA_ADMIN_PASSWORD=admin

# Loki URL (leave empty to disable Loki log shipping, required for log aggregation)
Loki__Url=http://loki:3100

ADMIN_PANEL_PASSWORD="sua-senha-super-secreta-123"