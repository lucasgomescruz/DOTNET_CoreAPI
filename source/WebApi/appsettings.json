{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Redis": {
    "Connection": ""
  },
  "RabbitMQ": {
    "Connection": "",
    "EmailQueue": ""
  },
  "AppSettings": {
    "BaseUrl": "http://localhost:5000",
    "ProjectName": "",
    "ProjectOwner": "",
    "InterfaceUrl": "",
    "EmailCooldownSeconds": ""
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Loki": {
    "Url": ""
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName" ],
    "Properties": {
      "Application": "WebAPI"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Secret": "",
    "Issuer": "",
    "Audience": "",
    "ExpirationMinutes": 60
  },
  "Email": {
    "Server": "",
    "Port": 587,
    "Username": "",
    "Password": "",
    "EnableSsl": true
  }
}