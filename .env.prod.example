# ⚠️  PRODUCTION ENVIRONMENT CONFIGURATION
# 
# DO NOT commit this file to version control
# Use this as a template and fill in with REAL production secrets
# 

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════════════════════

POSTGRES_USER=produser
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD_MIN_20_CHARS
POSTGRES_DB=coreapi-prod-db

# ═══════════════════════════════════════════════════════════════════════════════
# REDIS (Cache Layer)
# ═══════════════════════════════════════════════════════════════════════════════

REDIS_CONNECTION=redis-prod.your-domain.com:6379

# ═══════════════════════════════════════════════════════════════════════════════
# RABBITMQ (Message Queue)
# ═══════════════════════════════════════════════════════════════════════════════

RABBITMQ_CONNECTION=amqp://prod_user:CHANGE_ME_STRONG_PASSWORD@rabbitmq-prod.your-domain.com:5672/
RABBITMQ_EMAIL_QUEUE=email.queue.prod
RABBITMQ_USER=prod_user
RABBITMQ_PASS=CHANGE_ME_STRONG_PASSWORD

# ═══════════════════════════════════════════════════════════════════════════════
# APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

APP_SETTINGS__ProjectName=CoreAPI
APP_SETTINGS__ProjectOwner=Your Company Name
APP_SETTINGS__BASEURL=https://api.your-domain.com
APP_SETTINGS__InterfaceUrl=https://app.your-domain.com

# ═══════════════════════════════════════════════════════════════════════════════
# JWT AUTHENTICATION (⚠️  SECURITY CRITICAL)
# ═══════════════════════════════════════════════════════════════════════════════

JWT_SETTINGS_SECRET=GENERATE_STRONG_RANDOM_KEY_MIN_32_CHARS_BASE64_ENCODED
JWT_SETTINGS_ISSUER=your-api.your-domain.com
JWT_SETTINGS_AUDIENCE=your-app-client
JWT_SETTINGS_EXPIRATIONMINUTES=60

# ═══════════════════════════════════════════════════════════════════════════════
# EMAIL CONFIGURATION (SMTP)
# ═══════════════════════════════════════════════════════════════════════════════

EMAIL_SERVER=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USERNAME=apikey
EMAIL_PASSWORD=SG.YOUR_SENDGRID_API_KEY_HERE
EMAIL_ENABLESSL=true

# ═══════════════════════════════════════════════════════════════════════════════
# MONITORING & OBSERVABILITY (⚠️  SECURITY CRITICAL)
# ═══════════════════════════════════════════════════════════════════════════════

# Protect /metrics endpoint from unauthorized access
METRICS_API_KEY=GENERATE_STRONG_RANDOM_API_KEY_MIN_32_CHARS

# Loki log aggregation (optional — leave empty to disable)
Loki__Url=http://loki-prod.your-domain.com:3100

# Grafana admin (change immediately after first login!)
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD_MIN_16_CHARS

# ═══════════════════════════════════════════════════════════════════════════════
# DEPLOYMENT
# ═══════════════════════════════════════════════════════════════════════════════

# Deployment notes:
# 1. Generate strong random values for all CHANGE_ME entries (use: openssl rand -base64 32)
# 2. Use a secrets manager (HashiCorp Vault, AWS Secrets Manager, Azure Key Vault)
# 3. Never commit this file to version control
# 4. Rotate secrets regularly
# 5. Use HTTPS/TLS for all external connections
# 6. Enable authentication for Redis and RabbitMQ
# 7. Set ASPNETCORE_ENVIRONMENT=Production in docker-compose.yml
# 8. Monitor logs in Loki/Grafana for security events
